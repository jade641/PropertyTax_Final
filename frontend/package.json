{
  "name": "taxsync",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c cyan,magenta \"npm run dev:api\" \"npm run dev:web:wait\"",
    "dev:api": "dotnet run --project ../backend/PropertyTax.API/PropertyTax.API/PropertyTax.API.csproj",
    "dev:web": "vite",
    "dev:web:wait": "wait-on tcp:5079 && vite",
    "build": "vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "chart.js": "^4.5.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.511.0",
    "motion": "^12.23.12",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.10"
  }
}
